def list_images(folder: str):
    exts = ("*.jpg", "*.jpeg", "*.png", "*.bmp", "*.webp")
    files = []
    for e in exts:
        files.extend(glob.glob(str(Path(folder) / e)))
    return sorted(files)


def clamp(v, lo, hi):
    return max(lo, min(hi, v))


def xyxy_to_yolo(x1, y1, x2, y2, W, H):
    x1 = clamp(x1, 0, W - 1)
    y1 = clamp(y1, 0, H - 1)
    x2 = clamp(x2, 0, W - 1)
    y2 = clamp(y2, 0, H - 1)
    bw = max(1.0, x2 - x1)
    bh = max(1.0, y2 - y1)
    cx = x1 + bw / 2.0
    cy = y1 + bh / 2.0
    return (cx / W, cy / H, bw / W, bh / H)


def write_yolo_labels(txt_path: Path, det: sv.Detections, W: int, H: int):
    lines = []
    if det is None or len(det) == 0:
        txt_path.write_text("")  # empty file is valid
        return
    for (x1, y1, x2, y2), cid in zip(det.xyxy, det.class_id):
        cid = int(cid)
        cx, cy, w, h = xyxy_to_yolo(float(x1), float(y1), float(x2), float(y2), W, H)
        lines.append(f"{cid} {cx:.6f} {cy:.6f} {w:.6f} {h:.6f}")
    txt_path.write_text("\n".join(lines) + ("\n" if lines else ""))


def fit_for_display(img_bgr, max_w, max_h):
    h, w = img_bgr.shape[:2]
    scale = min(max_w / w, max_h / h, 1.0)
    if scale >= 1.0:
        return img_bgr
    return cv2.resize(img_bgr, (int(w * scale), int(h * scale)), interpolation=cv2.INTER_AREA)


def ensure_out_dirs(base: Path):
    (base / "images").mkdir(parents=True, exist_ok=True)
    (base / "labels").mkdir(parents=True, exist_ok=True)
    (base / "refuse" / "images").mkdir(parents=True, exist_ok=True)
    (base / "refuse" / "labels").mkdir(parents=True, exist_ok=True)


def save_pair(dest_root: Path, img_path: Path, frame_rgb: np.ndarray, det: sv.Detections, W: int, H: int):
    out_img = dest_root / "images" / img_path.name
    out_txt = dest_root / "labels" / f"{img_path.stem}.txt"

    cv2.imwrite(str(out_img), cv2.cvtColor(frame_rgb, cv2.COLOR_RGB2BGR))
    write_yolo_labels(out_txt, det, W, H)
    return out_img, out_txt


def edit_boxes_with_opencv(frame_rgb):
    frame_bgr = cv2.cvtColor(frame_rgb, cv2.COLOR_RGB2BGR)
    rois = cv2.selectROIs(
        "Edit: draw boxes, ENTER=finish, ESC=cancel",
        frame_bgr,
        fromCenter=False,
        showCrosshair=True
    )
    cv2.destroyWindow("Edit: draw boxes, ENTER=finish, ESC=cancel")

    if rois is None or len(rois) == 0:
        return sv.Detections.empty()

    new_xyxy, new_cids, new_confs = [], [], []
    print("\n[EDIT] For each ROI, enter class id (0=bolt, 1=shackle).")
    for i, (x, y, w, h) in enumerate(rois):
        x1, y1, x2, y2 = float(x), float(y), float(x + w), float(y + h)
        while True:
            k = input(f"ROI {i+1}/{len(rois)} class (0/1): ").strip()
            if k in ("0", "1"):
                cid = int(k)
                break
            print("  Please enter 0 or 1.")
        new_xyxy.append([x1, y1, x2, y2])
        new_cids.append(cid)
        new_confs.append(1.0)

    return sv.Detections(
        xyxy=np.array(new_xyxy, dtype=np.float32),
        confidence=np.array(new_confs, dtype=np.float32),
        class_id=np.array(new_cids, dtype=np.int32),
    )


def annotate_panel(frame_rgb: np.ndarray, det: sv.Detections, title: str,
                   box_annotator: sv.BoxAnnotator, label_annotator: sv.LabelAnnotator):
    # Build label strings including confidence
    labels = []
    if det is not None and len(det):
        for cid, conf in zip(det.class_id, det.confidence):
            cid = int(cid)
            name = CLASS_NAMES[cid] if 0 <= cid < len(CLASS_NAMES) else str(cid)
            labels.append(f"{name} {float(conf):.2f}")

    annotated = box_annotator.annotate(frame_rgb.copy(), det)
    annotated = label_annotator.annotate(annotated, det, labels)

    bgr = cv2.cvtColor(annotated, cv2.COLOR_RGB2BGR)
    cv2.putText(bgr, title, (10, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.9, (255,255,255), 2, cv2.LINE_AA)
    return bgr


def hstack_with_padding(left_bgr, right_bgr):
    # Make same height
    h1, w1 = left_bgr.shape[:2]
    h2, w2 = right_bgr.shape[:2]
    H = max(h1, h2)

    def pad_to_h(img, H):
        h, w = img.shape[:2]
        if h == H:
            return img
        pad = H - h
        return cv2.copyMakeBorder(img, 0, pad, 0, 0, borderType=cv2.BORDER_CONSTANT, value=(0,0,0))

    left_bgr = pad_to_h(left_bgr, H)
    right_bgr = pad_to_h(right_bgr, H)
    return np.hstack([left_bgr, right_bgr])


def main():
    img_files = list_images(IMAGES_DIR)
    if not img_files:
        raise SystemExit(f"No images found in {IMAGES_DIR}")

    out_dir = Path(OUT_DIR)
    ensure_out_dirs(out_dir)

    print(f"[INFO] Loading RF-DETR TOTAL: {WEIGHTS_TOTAL}")
    model_total = RFDETRMedium(pretrain_weights=WEIGHTS_TOTAL)
    print(f"[INFO] Loading RF-DETR EMA:   {WEIGHTS_EMA}")
    model_ema   = RFDETRMedium(pretrain_weights=WEIGHTS_EMA)

    box_annotator = sv.BoxAnnotator()
    label_annotator = sv.LabelAnnotator()

    idx = 0
    edited_det = None  # holds edited boxes temporarily

    while idx < len(img_files):
        path = Path(img_files[idx])
        img_pil = Image.open(path).convert("RGB")
        W, H = img_pil.size
        frame_rgb = np.array(img_pil)

        det_total = model_total.predict(img_pil, threshold=THRESHOLD)
        det_ema   = model_ema.predict(img_pil, threshold=THRESHOLD)

        left  = annotate_panel(frame_rgb, det_total, "TOTAL (checkpoint_best_total.pth)", box_annotator, label_annotator)
        right = annotate_panel(frame_rgb, det_ema,   "EMA   (checkpoint_best_ema.pth)",   box_annotator, label_annotator)

        comp = hstack_with_padding(left, right)

        cv2.putText(
            comp,
            f"{idx+1}/{len(img_files)}  1=accept total  2=accept ema  !=refuse total  @=refuse ema  e=edit  s=skip  q=quit",
            (10, comp.shape[0] - 20),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.7,
            (255, 255, 255),
            2,
            cv2.LINE_AA
        )

        display_img = fit_for_display(comp, DISPLAY_MAX_W, DISPLAY_MAX_H)
        cv2.imshow(WINDOW_NAME, display_img)
        key = cv2.waitKey(0) & 0xFF

        if key == ord("q"):
            break

        elif key == ord("s"):
            print(f"[SKIP] {path.name}")
            edited_det = None
            idx += 1
            continue

        elif key == ord("e"):
            edited_det = edit_boxes_with_opencv(frame_rgb)
            # after edit, stay on same image, wait for save/refuse choice
            print("[EDIT] Now press 1/2 to ACCEPT edited for total/ema slot, or !/@ to REFUSE edited, or s to skip.")
            continue

        # Decide which detections to save
        # If edited_det exists, use it; otherwise use chosen model output.
        if key == ord("1"):  # accept TOTAL
            det_to_save = edited_det if edited_det is not None else det_total
            out_img, out_txt = save_pair(out_dir, path, frame_rgb, det_to_save, W, H)
            print(f"[ACCEPT TOTAL] {path.name} -> {out_img} + {out_txt}")

        elif key == ord("2"):  # accept EMA
            det_to_save = edited_det if edited_det is not None else det_ema
            out_img, out_txt = save_pair(out_dir, path, frame_rgb, det_to_save, W, H)
            print(f"[ACCEPT EMA] {path.name} -> {out_img} + {out_txt}")

        elif key == ord("!"):  # refuse TOTAL
            det_to_save = edited_det if edited_det is not None else det_total
            refuse_root = out_dir / "refuse"
            out_img, out_txt = save_pair(refuse_root, path, frame_rgb, det_to_save, W, H)
            print(f"[REFUSE TOTAL] {path.name} -> {out_img} + {out_txt}")

        elif key == ord("@"):  # refuse EMA
            det_to_save = edited_det if edited_det is not None else det_ema
            refuse_root = out_dir / "refuse"
            out_img, out_txt = save_pair(refuse_root, path, frame_rgb, det_to_save, W, H)
            print(f"[REFUSE EMA] {path.name} -> {out_img} + {out_txt}")

        else:
            print("[INFO] Unknown key. Use 1/2/!/ @/e/s/q.")
            continue

        # move forward after a save
        edited_det = None
        idx += 1

    cv2.destroyAllWindows()
    print(f"[DONE] Saved dataset to: {OUT_DIR}")
    print(f"       accept: {OUT_DIR}/images + {OUT_DIR}/labels")
    print(f"       refuse: {OUT_DIR}/refuse/images + {OUT_DIR}/refuse/labels")
    print("       Class mapping: 0 bolt, 1 shackle")


if __name__ == "__main__":
    main()