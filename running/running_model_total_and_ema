IMAGES_DIR = "/home/jeff/Desktop/Project_Occulus/ComputerVision_WorkSpace/datasets/raw/photos/raw_consolidated/standardized_1120"
OUT_DIR    = "/home/jeff/Desktop/Project_Occulus/ComputerVision_WorkSpace/datasets/raw/photos/raw_consolidated/standardized_1120_labeled"

WEIGHTS_TOTAL = "/home/jeff/Desktop/Project_Occulus/ComputerVision_WorkSpace/results/model_4_2/checkpoint_best_total.pth"
WEIGHTS_EMA   = "/home/jeff/Desktop/Project_Occulus/ComputerVision_WorkSpace/results/model_7_0/checkpoint_best_total.pth"

THRESHOLD  = 0.60
